{
  "name": "kobeanrest",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "description": "Local-first desktop API client for REST and HTTP workflows.",
  "scripts": {
    "test": "node --test",
    "check:local-only": "node tests/local-only-contract.test.mjs",
    "check:release": "node scripts/check-release-preflight.mjs",
    "check:secrets": "node scripts/check-secrets.mjs",
    "check:native": "cargo check --manifest-path src-tauri/Cargo.toml",
    "dev": "vite",
    "build": "tsc && vite build",
    "build:docs": "npm --prefix docs-site run build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
