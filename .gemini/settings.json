{
  "mcpServers": {
    "code-review-graph": {
      "command": "uvx",
      "args": [
        "code-review-graph",
        "serve"
      ],
      "cwd": "/Users/thanh.nguyen/Desktop/projects/KobeanREST"
    },
    "toon": {
      "command": "npx",
      "args": [
        "-y",
        "git+https://github.com/kweinmeister/toon-mcp.git"
      ]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .gemini/hooks/crg-session-start.sh",
            "name": "code-review-graph status",
            "timeout": 10000
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "write_file|replace",
        "hooks": [
          {
            "type": "command",
            "command": "bash .gemini/hooks/crg-update.sh",
            "name": "code-review-graph update",
            "timeout": 30000
          }
        ]
      }
    ]
  }
}